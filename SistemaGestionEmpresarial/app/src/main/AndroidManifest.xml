<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos para conectar con la API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SistemaGestionEmpresarial"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- LoginActivity - Pantalla Principal (LAUNCHER) -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- PunchActivity - Pantalla de Fichaje -->
        <activity
            android:name=".ui.punch.PunchActivity"
            android:exported="false" />

        <!-- PunchHistoryActivity - Historial de Fichajes -->
        <activity
            android:name=".ui.history.PunchHistoryActivity"
            android:exported="false" />

        <!-- EmployeesActivity - Gestión de Empleados -->
        <activity
            android:name=".ui.employees.EmployeesActivity"
            android:exported="false" />

        <!-- MainActivity (original, la dejamos por si acaso) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
    </application>
</manifest>